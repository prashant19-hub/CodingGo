)

const BOARD_SIZE = 52
const HOME_POS = -1
const FINISH_POS = 57

type Player struct {
    Name   string
    Pieces [4]int // positions: -1=home, 0-51=board, 52-56=finish path, 57=done
    ID     int
}

type Game struct {
    Players [2]Player
    Current int
    Turn    int
}

func clearScreen() {
    cmd := exec.Command("clear")
    if os.Getenv("OS") == "Windows_NT" {
        cmd = exec.Command("cls")
    }
    cmd.Stdout = os.Stdout
    cmd.Run()
}

func (g *Game) RollDice() int {
    rand.Seed(time.Now().UnixNano())
    return rand.Intn(6) + 1
}

func (g *Game) CanMove(player int, piece int, roll int) bool {
    pos := g.Players[player].Pieces[piece]
    if pos == FINISH_POS {
        return false
    }
    
    // Open from home
    if pos == HOME_POS && roll == 6 {
        return true
    }
    
    // Normal move
    if pos != HOME_POS {
        newPos := (pos + roll) % BOARD_SIZE
        if newPos >= 52 {
            newPos -= BOARD_SIZE
        }
        return true
    }
    return false
}

func (g *Game) MovePiece(player int, piece int, roll int) {
    pos := g.Players[player].Pieces[piece]
    if pos == HOME_POS && roll == 6 {
        g.Players[player].Pieces[piece] = 0
    } else if pos != HOME_POS && pos != FINISH_POS {
        newPos := pos + roll
        if newPos >= 52 {
            newPos = 52 + (newPos - 52) // enter finish path
        }
        if newPos >= FINISH_POS {
            newPos = FINISH_POS
        }
        g.Players[player].Pieces[piece] = newPos % BOARD_SIZE
    }
}

func (g *Game) PrintBoard() {
    clearScreen()
    fmt.Println("🎲 LUDO GAME - Player", g.Current+1, "'s Turn")
    fmt.Println("Roll: Enter piece number (1-4) or 'r' to roll dice")
    
    for i := 0; i < 4; i++ {
        p1pos := g.Players[0].Pieces[i]
        p2pos := g.Players[1].Pieces[i]
        status1 := "🏠"
        status2 := "🏠"
        
        if p1pos >= 0 {
            status1 = "🔴" + strconv.Itoa(p1pos)
        }
        if p2pos >= 0 {
            status2 = "🔵" + strconv.Itoa(p2pos)
        }
        
        fmt.Printf("Piece %d: P1:%s  P2:%s
", i+1, status1, status2)
    }
    fmt.Println("
Commands: 1-4 (move piece), r (roll), q (quit)")
}

func (g *Game) IsWinner() int {
    for i, p := range g.Players {
        allDone := true
        for _, pos := range p.Pieces {
            if pos != FINISH_POS {
                allDone = false
                break
            }
        }
        if allDone {
            return i
        }
    }
    return -1
}

func main() {
    game := Game{
        Players: [2]Player{
            {Name: "Player 1 (Red)", ID: 0},
            {Name: "Player 2 (Blue)", ID: 1},
        },
        Current: 0,
    }
    
    for {
        game.PrintBoard()
        fmt.Print("Your move: ")
        
        var input string
        fmt.Scanln(&input)
        
        if input == "q" {
            fmt.Println("Game quit!")
            break
        }
        
        if input == "r" {
            roll := game.RollDice()
            fmt.Println("🎲 Dice:", roll)
            
            if roll == 6 {
                fmt.Println("Extra turn!")
                continue
            }
            game.Turn++
            game.Current = (game.Current + 1) % 2
            time.Sleep(2 * time.Second)
            continue
        }
        
        pieceIdx, err := strconv.Atoi(input)
        if err != nil || pieceIdx < 1 || pieceIdx > 4 {
            fmt.Println("Invalid! Use 1-4")
            time.Sleep(1 * time.Second)
            continue
        }
        
        pieceIdx--
        roll := game.RollDice()
        
        if game.CanMove(game.Current, pieceIdx, roll) {
            game.MovePiece(game.Current, pieceIdx, roll)
            fmt.Printf("Moved piece %d by %d spaces!
", pieceIdx+1, roll)
            
            if roll == 6 {
                fmt.Println("Extra turn! (Roll again)")
            } else {
                game.Current = (game.Current + 1) % 2
            }
        } else {
            fmt.Println("Can't move that piece!")
        }
        
        winner := game.IsWinner()
        if winner != -1 {
            game.PrintBoard()
            fmt.Printf("🎉 %s WINS!
", game.Players[winner].Name)
            break
        }
        
        time.Sleep(2 * time.Second)
    }
