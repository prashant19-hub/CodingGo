import (
    "fmt"
    "math/rand"
    "time"
)

type Player struct {
    Name      string
    Health    int
    Money     int
    Wanted    int
    PosX, PosY int
    Car       string
    Weapon    string
}

type NPC struct {
    Name   string
    PosX, PosY int
    Alive  bool
}

type Game struct {
    Player Player
    NPCs   []NPC
    Turn   int
    Mission string
}

func clearScreen() {
    fmt.Print("\u001B[2J\u001B[H")
}

func NewGame() *Game {
    weapons := []string{"Pistol", "AK47", "Shotgun"}
    cars := []string{"BMW", "Lamborghini", "Police Car"}
    
    return &Game{
        Player: Player{
            Name:   "CJ",
            Health: 100,
            Money:  1000,
            Wanted: 0,
            PosX:   50,
            PosY:   50,
            Car:    cars[rand.Intn(len(cars))],
            Weapon: weapons[0],
        },
        NPCs: make([]NPC, 5),
        Mission: "Steal a car",
    }
}

func (g *Game) PrintStatus() {
    clearScreen()
    fmt.Println("🚗 GRAND THEFT AUTO - CJ's Adventure")
    fmt.Println("=====================================")
    fmt.Printf("💰 Money: $%d | ❤️ Health: %d | ⭐ Wanted Level: %d
", 
        g.Player.Money, g.Player.Health, g.Player.Wanted)
    fmt.Printf("🚙 Car: %s | 🔫 Weapon: %s
", g.Player.Car, g.Player.Weapon)
    fmt.Printf("📍 Location: (%d, %d)

", g.Player.PosX, g.Player.PosY)
    fmt.Printf("🎯 Mission: %s

", g.Mission)
    fmt.Println("Commands: [d]rive [s]hoot [r]ob [b]uy [h]eal [m]ission [e]scape")
}

func (g *Game) Drive() {
    directions := []string{"North", "South", "East", "West"}
    dir := directions[rand.Intn(len(directions))]
    distance := rand.Intn(10) + 5
    
    switch dir {
    case "North": g.Player.PosY += distance
    case "South": g.Player.PosY -= distance
    case "East": g.Player.PosX += distance
    case "West": g.Player.PosX -= distance
    }
    
    g.Player.PosX = clamp(g.Player.PosX, 0, 99)
    g.Player.PosY = clamp(g.Player.PosY, 0, 99)
    
    fmt.Printf("🚗 Drove %d blocks %s to (%d,%d)
", distance, dir, g.Player.PosX, g.Player.PosY)
    
    // Random money pickup
    if rand.Intn(100) < 20 {
        money := rand.Intn(500) + 100
        g.Player.Money += money
        fmt.Printf("💵 Found $%d on the street!
", money)
    }
}

func (g *Game) Shoot() {
    if len(g.NPCs) == 0 {
        fmt.Println("No targets nearby!")
        return
    }
    
    target := rand.Intn(len(g.NPCs))
    if g.NPCs[target].Alive {
        damage := rand.Intn(50) + 25
        g.NPCs[target].Alive = false
        money := rand.Intn(200) + 50
        g.Player.Money += money
        g.Player.Wanted += 1
        
        fmt.Printf("💥 Shot %s! +$%d (Wanted: %d)
", g.NPCs[target].Name, money, g.Player.Wanted)
    }
}

func (g *Game) RobStore() {
    success := rand.Intn(100) < 70
    if success {
        money := rand.Intn(2000) + 1000
        g.Player.Money += money
        g.Player.Wanted += 2
        fmt.Printf("🏦 Robbed store! +$%d (Wanted: %d)
", money, g.Player.Wanted)
    } else {
        g.Player.Health -= 20
        g.Player.Wanted += 3
        fmt.Printf("😵 Robbery failed! -20 HP (Wanted: %d)
", g.Player.Wanted)
    }
}

func (g *Game) BuyWeapon() {
    if g.Player.Money < 500 {
        fmt.Println("Not enough money!")
        return
    }
    
    weapons := map[string]int{"Pistol": 500, "AK47": 1500, "Shotgun": 2000}
    weapon := "AK47"
    cost := 1500
    
    if g.Player.Money >= 2000 {
        weapon = "Shotgun"
        cost = 2000
    } else if g.Player.Money >= 1500 {
        weapon = "AK47"
        cost = 1500
    }
    
    g.Player.Weapon = weapon
    g.Player.Money -= cost
    fmt.Printf("🛒 Bought %s for $%d
", weapon, cost)
}

func (g *Game) Heal() {
    if g.Player.Money < 200 {
        fmt.Println("Not enough money for medkit!")
        return
    }
    
    heal := 50
    g.Player.Health += heal
    if g.Player.Health > 100 {
        g.Player.Health = 100
    }
    g.Player.Money -= 200
    fmt.Printf("❤️ Healed +%d HP (%d/100)
", heal, g.Player.Health)
}

func (g *Game) DoMission() {
    missions := []string{
        "Deliver package (+$5000)",
        "Steal car (+$3000)", 
        "Assassinate target (+$8000)",
        "Bank heist (+$15000)",
    }
    
    mission := missions[rand.Intn(len(missions))]
    g.Mission = mission
    
    success := rand.Intn(100) < 80
    if success {
        money := rand.Intn(10000) + 3000
        g.Player.Money += money
        fmt.Printf("✅ Mission complete! +$%d
", money)
    } else {
        g.Player.Health -= 30
        fmt.Printf("❌ Mission failed! -30 HP
")
    }
}

func (g *Game) PoliceChase() {
    if g.Player.Wanted > 0 {
        escapeChance := 70 - (g.Player.Wanted * 10)
        if rand.Intn(100) < escapeChance {
            g.Player.Wanted = 0
            fmt.Println("🚓 Escaped police!")
        } else {
            g.Player.Health -= 25 * g.Player.Wanted
            g.Player.Wanted = 0
            fmt.Printf("🚨 Caught by police! -%d HP
", 25*g.Player.Wanted)
        }
    }
}

func (g *Game) SpawnNPCs() {
    names := []string{"Gangster", "Cop", "Civilian", "Rival", "Dealer"}
    for i := range g.NPCs {
        g.NPCs[i] = NPC{
            Name:  names[rand.Intn(len(names))],
            PosX:  rand.Intn(100),
            PosY:  rand.Intn(100),
            Alive: true,
        }
    }
}

func clamp(val, min, max int) int {
    if val < min { return min }
    if val > max { return max }
    return val
}

func (g *Game) IsGameOver() bool {
    return g.Player.Health <= 0 || g.Player.Money >= 50000
}

