var indexTmpl = `<!DOCTYPE html>
<html><body>
<h1>Calculator</h1>
<form action="/calculate" method="post">
Num1: <input type="number" name="num1" step="0.01"><br>
Operator: <select name="op">
<option>+</option><option>-</option><option>*</option><option>/</option>
</select><br>
Num2: <input type="number" name="num2" step="0.01"><br>
<input type="submit" value="Calculate">
</form>{{if .Result}}<h2>Result: {{.Result}}</h2>{{end}}</body></html>`
func calculatorHandler(w http.ResponseWriter, r *http.Request) {
    tmpl := template.Must(template.New("index").Parse(indexTmpl))
    tmpl.Execute(w, nil)
}
func calculateHandler(w http.ResponseWriter, r *http.Request) {
    if r.Method != "POST" { http.Redirect(w, r, "/", http.StatusSeeOther); return }
    num1Str := r.FormValue("num1")
    op := r.FormValue("op")
    num2Str := r.FormValue("num2")
    num1, _ := strconv.ParseFloat(num1Str, 64)
    num2, _ := strconv.ParseFloat(num2Str, 64)
    var result float64
    switch op {
    case "+": result = num1 + num2
    case "-": result = num1 - num2
    case "*": result = num1 * num2
    case "/":
        if num2 == 0 { http.Error(w, "Division by zero!", http.StatusBadRequest); return }
        result = num1 / num2
    }
    tmpl := template.Must(template.New("result").Parse(indexTmpl))
    tmpl.Execute(w, struct{ Result string }{fmt.Sprintf("%.2f", result)})
}
func main() {
    http.HandleFunc("/", calculatorHandler)
    http.HandleFunc("/calculate", calculateHandler)
    fmt.Println("Server: http://localhost:8080")
    http.ListenAndServe(":8080", nil)
