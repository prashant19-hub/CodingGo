type Player struct {
    Name    string
    Health  int
    PosX, PosY int
    Weapon  string
    Alive   bool
}

type Zone struct {
    X1, Y1, X2, Y2 int
    Radius   int
}

type Game struct {
    Players []Player
    Zone    Zone
    Turn    int
}

func NewPlayer(name string) Player {
    weapons := []string{"M416", "AKM", "SCAR-L", "AWM"}
    return Player{
        Name:   name,
        Health: 100,
        PosX:   rand.Intn(100),
        PosY:   rand.Intn(100),
        Weapon: weapons[rand.Intn(len(weapons))],
        Alive:  true,
    }
}

func (g *Game) Init() {
    names := []string{"You", "Enemy1", "Enemy2", "Enemy3", "Enemy4", 
                      "Enemy5", "Enemy6", "Enemy7", "Enemy8", "Enemy9"}
    g.Players = make([]Player, 10)
    for i := range names {
        g.Players[i] = NewPlayer(names[i])
    }
    g.Zone = Zone{25, 25, 75, 75, 50}
}

func clearScreen() {
    fmt.Print("\u001B[2J\u001B[H")
}

func (g *Game) PrintStatus() {
    clearScreen()
    fmt.Println("🔫 PUBG BATTLE ROYALE - Turn", g.Turn)
    fmt.Println("========================")
    
    aliveCount := 0
    yourPos := 0
    for i, p := range g.Players {
        if p.Alive {
            aliveCount++
            if p.Name == "You" {
                yourPos = i
                fmt.Printf("✅ YOU: %s (HP:%d) at (%d,%d) | Zone: %d->%d
", 
                    p.Weapon, p.Health, p.PosX, p.PosY, g.Zone.X1, g.Zone.X2)
            }
        }
    }
    fmt.Printf("Alive: %d/10 | Zone shrinking...

", aliveCount)
    
    fmt.Println("Commands: [s]hoot [m]ove [l]oot [h]eal [w]ait")
}

func (g *Game) ShrinkZone() {
    g.Zone.Radius -= 2
    g.Zone.X1 = 50 - g.Zone.Radius/2
    g.Zone.X2 = 50 + g.Zone.Radius/2
    g.Zone.Y1 = 50 - g.Zone.Radius/2
    g.Zone.Y2 = 50 + g.Zone.Radius/2
    
    // Damage players outside zone
    for i := range g.Players {
        if g.Players[i].Alive {
            dist := distance(g.Players[i].PosX, g.Players[i].PosY, 50, 50)
            if dist > g.Zone.Radius {
                g.Players[i].Health -= 10
                if g.Players[i].Health <= 0 {
                    g.Players[i].Alive = false
                }
            }
        }
    }
}

func distance(x1, y1, x2, y2 int) int {
    dx := x1 - x2
    dy := y1 - y2
    return int((float64(dx*dx + dy*dy)))
}

func (g *Game) Shoot() {
    target := rand.Intn(9)
    if target == 0 { target = 1 } // Don't shoot self
    
    if g.Players[target].Alive {
        damage := rand.Intn(40) + 20
        g.Players[target].Health -= damage
        fmt.Printf("💥 Shot %s with %s! -%d HP (%d left)
", 
            g.Players[target].Name, g.Players[0].Weapon, damage, g.Players[target].Health)
        
        if g.Players[target].Health <= 0 {
            g.Players[target].Alive = false
            fmt.Printf("%s eliminated!
", g.Players[target].Name)
        }
    }
}

func (g *Game) Move() {
    dx := rand.Intn(21) - 10 // -10 to +10
    dy := rand.Intn(21) - 10
    g.Players[0].PosX = clamp(g.Players[0].PosX+dx, 0, 99)
    g.Players[0].PosY = clamp(g.Players[0].PosY+dy, 0, 99)
    fmt.Printf("Moved to (%d,%d)
", g.Players[0].PosX, g.Players[0].PosY)
}

func clamp(val, min, max int) int {
    if val < min { return min }
    if val > max { return max }
    return val
}

func (g *Game) Loot() {
    weapons := []string{"M416", "AKM", "SCAR-L", "AWM", "Groza"}
    g.Players[0].Weapon = weapons[rand.Intn(len(weapons))]
    fmt.Printf("🔫 Looted %s!
", g.Players[0].Weapon)
}

func (g *Game) Heal() {
    if g.Players[0].Health < 100 {
        heal := rand.Intn(41) + 10
        g.Players[0].Health += heal
        if g.Players[0].Health > 100 {
            g.Players[0].Health = 100
        }
        fmt.Printf("❤️ Healed +%d HP (%d/100)
", heal, g.Players[0].Health)
    }
}

func (g *Game) AIEnemies() {
    for i := 1; i < 10; i++ {
        if g.Players[i].Alive && rand.Float64() < 0.3 {
            // 30% chance AI shoots
            target := rand.Intn(10)
            if target != i && g.Players[target].Alive {
                dmg := rand.Intn(30) + 10
                g.Players[target].Health -= dmg
                if g.Players[target].Health <= 0 {
                    g.Players[target].Alive = false
                }
            }
        }
    }
}

func (g *Game) IsGameOver() bool {
    aliveCount := 0
    for _, p := range g.Players {
        if p.Alive { aliveCount++ }
    }
    return aliveCount <= 1
}

func main() {
    rand.Seed(time.Now().UnixNano())
    game := Game{}
    game.Init()
    
    for {
        game.Turn++
        game.ShrinkZone()
        game.PrintStatus()
        
        if game.IsGameOver() {
            fmt.Println("🎉 CHICKEN DINNER! You Win!")
            break
        }
        
        var cmd string
        fmt.Print("Action: ")
